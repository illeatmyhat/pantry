{
  "name": "@illeatmyhat/pantry",
  "version": "0.0.0",
  "private": true,
  "description": "The USDA SR Legacy dataset as pay-per-import modules, localized, with a toolkit for building ingredient layers on top.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/toolkit/index.d.ts",
      "default": "./dist/toolkit/index.js"
    },
    "./sr/*/full": "./generated/sr/*.full.js",
    "./sr/*": "./generated/sr/*.js",
    "./manifest.json": "./generated/manifest.json"
  },
  "bin": {
    "pantry": "./dist/toolkit/cli.js"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsx src/generator/build.ts",
    "build:toolkit": "tsc -p tsconfig.build.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/illeatmyhat/pantry.git"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@types/node": "^25.9.3",
    "fflate": "^0.8.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
